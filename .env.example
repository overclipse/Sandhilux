# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=sandhilux
POSTGRES_PASSWORD=change-me-to-a-random-password
POSTGRES_DB=sandhilux

# ── Optional ──────────────────────────────────────────────────────────────────
# Port exposed by Docker Compose (default: 8080)
PORT=8080

# Server bind address (local dev)
HTTP_ADDR=:8080

# CORS origin (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
